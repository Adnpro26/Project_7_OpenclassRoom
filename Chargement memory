import pickle
import os

class Transco:
    _data = None

    @classmethod
    def load(cls, path):
        import yaml
        with open(path, "r") as f:
            cls._data = yaml.safe_load(f)

    @classmethod
    def save_cache(cls, path="temp/transco.pkl"):
        with open(path, "wb") as f:
            pickle.dump(cls._data, f)

    @classmethod
    def load_cache(cls, path="temp/transco.pkl"):
        if os.path.exists(path):
            with open(path, "rb") as f:
                cls._data = pickle.load(f)


