import customtkinter as ctk

ctk.set_appearance_mode("light")  # Excel = light only
ctk.set_default_color_theme("theme_excel_2025.json")

root = ctk.CTk()
root.title("Reporting Excel-like")
root.geometry("900x600")

ctk.CTkLabel(root, text="Reporting Finance").pack(pady=10)
ctk.CTkEntry(root, placeholder_text="Période").pack(pady=5)
ctk.CTkButton(root, text="Générer le reporting").pack(pady=20)

root.mainloop()



