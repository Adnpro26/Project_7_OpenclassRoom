import ttkbootstrap as ttk
from ttkbootstrap.constants import *

def open_adjustments_manager(self):

    win = ttk.Window(themename="flatly")
    win.title("Gestion des ajustements")

    width = int(self.root.winfo_screenwidth() * 0.8)
    height = int(self.root.winfo_screenheight() * 0.7)
    win.geometry(f"{width}x{height}")

    df = load_adjustments()
    self.adjustments_df = df

    main_frame = ttk.Frame(win)
    main_frame.pack(fill=BOTH, expand=True)

    # Frame pour Treeview + scrollbar
    table_frame = ttk.Frame(main_frame)
    table_frame.pack(fill=BOTH, expand=True)

    # Scrollbar
    scrollbar = ttk.Scrollbar(table_frame, orient=VERTICAL)
    scrollbar.pack(side=RIGHT, fill=Y)

    # Treeview
    columns = df.columns.tolist()

    tree = ttk.Treeview(
        table_frame,
        columns=columns,
        show="headings",
        yscrollcommand=scrollbar.set
    )

    for col in columns:
        tree.heading(col, text=col)
        tree.column(col, width=150, anchor="w")

    for i, row in df.iterrows():
        tree.insert("", "end", values=row.tolist())

    tree.pack(side=LEFT, fill=BOTH, expand=True)

    # Liaison scrollbar
    scrollbar.config(command=tree.yview)

    # Boutons
    btn_frame = ttk.Frame(main_frame)
    btn_frame.pack(fill=X, pady=5)

    ttk.Button(btn_frame, text="Supprimer").pack(side=LEFT, padx=5)
    ttk.Button(btn_frame, text="Modifier").pack(side=LEFT, padx=5)
